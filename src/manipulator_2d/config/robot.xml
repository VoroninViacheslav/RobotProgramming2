<mujoco model="2d_arm_floating_base">
  <compiler angle="degree" coordinate="local"/>
  <option timestep="0.005" gravity="0 0 -9.81" iterations="30" tolerance="1e-8"/>

  <default>
    <joint limited="true" damping="0.5"/>
    <geom friction="0.3 0.005 0.0001" solimp="0.9 0.95 0.001" solref="0.02 1"/>
  </default>

  <worldbody>
    <light name="light" pos="0 0 2" dir="0 0 -1" directional="true"/>
    <geom name="ground" type="plane" pos="0 0 -0.1" size="5 5 0.1" rgba="0.2 0.2 0.2 1"/>

    <body name="base" pos="0 0 0">
      <joint name="base_x" type="slide" axis="1 0 0" range="-2 2" damping="5.0"/>
      <joint name="base_y" type="slide" axis="0 1 0" range="-2 2" damping="5.0"/>
      <joint name="base_rot" type="hinge" axis="0 0 1" range="-180 180" damping="2.0"/>
      <geom name="base_geom" type="box" size="0.15 0.15 0.03" rgba="0.6 0.2 0.2 1" mass="2.0"/>

      <body name="link1" pos="0.2 0 0">
        <joint name="joint1" type="hinge" axis="0 0 1" range="-180 180" damping="0.5"/>
        <geom name="link1_geom" type="box" size="0.18 0.025 0.025" rgba="0.2 0.6 0.2 1" mass="0.8" pos="0.09 0 0"/>
        <body name="link2" pos="0.18 0 0">
          <joint name="joint2" type="hinge" axis="0 0 1" range="-180 180" damping="0.5"/>
          <geom name="link2_geom" type="box" size="0.15 0.025 0.025" rgba="0.2 0.2 0.8 1" mass="0.6" pos="0.075 0 0"/>
          <body name="link3" pos="0.15 0 0">
            <joint name="joint3" type="hinge" axis="0 0 1" range="-180 180" damping="0.5"/>
            <geom name="link3_geom" type="box" size="0.12 0.02 0.02" rgba="0.8 0.2 0.8 1" mass="0.4" pos="0.06 0 0"/>
            <body name="end_effector" pos="0.12 0 0">
              <geom name="gripper" type="sphere" size="0.03" rgba="0.8 0.8 0 1" mass="0.02"/>
              <site name="eef_site" pos="0 0 0"/>
            </body>
          </body>
        </body>
      </body>
    </body>

    <body name="object" pos="0 0 0">
      <joint name="obj_x" type="slide" axis="1 0 0" range="-5 5" damping="100.0"/>
      <joint name="obj_y" type="slide" axis="0 1 0" range="-5 5" damping="100.0"/>
      <geom name="object_geom" type="sphere" size="0.035" rgba="1 0.5 0 1" mass="0.1"/>
      <site name="object_site" pos="0 0 0"/>
    </body>

    <site name="target_site" pos="0.6 0.4 0" size="0.03" rgba="0 1 0 0.5" type="sphere"/>
  </worldbody>

  <actuator>
    <motor name="joint1_motor" joint="joint1" gear="100" ctrlrange="-20 20"/>
    <motor name="joint2_motor" joint="joint2" gear="80" ctrlrange="-20 20"/>
    <motor name="joint3_motor" joint="joint3" gear="60" ctrlrange="-20 20"/>
  </actuator>
</mujoco>
